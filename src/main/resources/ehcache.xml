	<!-- 缓存模版 由uses-template属性引用此模板-->
    <cache-template name="template">
    	<!--键值对被声明为字符串类型，如果没有指明，默认是Object类型。
        <key-type>java.lang.String</key-type>-->
        <value-type copier="cms.cache.EhcacheCopyStrategy">java.lang.Object</value-type>
    </cache-template>



    <!-- 管理员 - 刷新令牌 604800为7天  本项配置不生效，仅占位用，具体由application.yml的bbs.admin.refreshToken-expiration配置起作用 -->
    <cache alias="adminCacheManager_cache_refreshToken" uses-template="template">
        <expiry>
            <!-- 通过ttl指定了cache过期时间,java.util.concurrent.TimeUnit中的属性，单位/秒 -->
            <ttl unit="seconds">6048000</ttl>
        </expiry>
        <resources>
            <heap unit="entries">99999999</heap>
        </resources>
    </cache>
